{
  "name": "terraform-registry-frontend",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "visualize": "VITE_ANALYZE=true vite build",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css,json}'",
    "generate:api": "bash scripts/generate-api-client.sh",
    "generate:swagger-snapshot": "bash scripts/update-swagger-snapshot.sh",
    "contract:check": "npx openapi-typescript openapi/swagger.json --output src/services/generated/api.ts && tsc --noEmit"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.10",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "axios": "^1.15.1",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.0.5",
    "react-i18next": "^15.4.1",
    "cmdk": "^1.1.1",
    "jwt-decode": "^4.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.30.3",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.17.0",
    "swagger-ui-react": "^5.32.4",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.2",
    "@sentry/react": "^10.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/swagger-ui-react": "^5.18.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.4",
    "openapi-typescript": "^7.4.4"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ]
}
