    "react-i18next": "^17.0.10",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.27.0",
    "swagger-ui-react": "^5.32.9",
    "web-vitals": "^5.3.0"
